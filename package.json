{
  "name": "mostrador",
  "private": true,
  "version": "0.1.0",
  "description": "Mostrador — SaaS de punto de venta y gestión para comercios (monorepo)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @mostrador/web",
    "build:web": "npm run build -w @mostrador/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "smoke": "npm run smoke -w @mostrador/web"
  },
  "engines": {
    "node": ">=20"
  }
}
