# Base de datos PostgreSQL (Supabase).
# DATABASE_URL = pooler (transaction mode, puerto 6543) — lo usa la app.
# DIRECT_URL   = conexión directa/session (puerto 5432) — la usan las migraciones de Prisma.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Auth
JWT_SECRET="cambiar-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
# Orígenes permitidos para CORS (separados por coma). En dev, el frontend Vite.
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"
