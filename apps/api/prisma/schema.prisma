// Schema base del SaaS Mostrador.
// Fase 1-2: tablas core (negocios, sucursales, usuarios, planes, suscripciones, settings).
// Las tablas operativas (products, sales, cash_registers, etc.) se agregan en fases
// posteriores, SIEMPRE con `businessId` (y `branchId` donde corresponda) para el
// aislamiento multi-tenant. Ver docs/HANDOFF-arquitectura-produccion.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusinessStatus {
  active
  suspended
  cancelled
}

enum UserRole {
  admin
  manager
  seller
}

enum UserStatus {
  active
  inactive
}

enum SubscriptionStatus {
  trial
  active
  past_due
  cancelled
  expired
  blocked
}

/// Cada suscriptor = un negocio. Es la raíz del aislamiento multi-tenant.
model Business {
  id        String         @id @default(cuid())
  name      String
  category  String         @default("")
  cuit      String         @default("")
  phone     String         @default("")
  email     String         @default("")
  address   String         @default("")
  logoUrl   String?
  status    BusinessStatus @default(active)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  settings      BusinessSettings?
  branches      Branch[]
  users         User[]
  subscription  Subscription?
  categories    Category[]
  brands        Brand[]
  products      Product[]
  customers     Customer[]

  @@map("businesses")
}

model BusinessSettings {
  id                     String   @id @default(cuid())
  businessId             String   @unique
  currency               String   @default("ARS")
  primaryColor           String   @default("#2563eb")
  theme                  String   @default("light")
  requireOpenCashToSell  Boolean  @default(true)
  allowNegativeStock     Boolean  @default(false)
  allowDiscounts         Boolean  @default(true)
  maxDiscountPercent     Int      @default(20)
  allowCustomerCredit    Boolean  @default(true)
  defaultMinStock        Int      @default(5)
  receiptMessage         String   @default("¡Gracias por tu compra!")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_settings")
}

model Branch {
  id         String   @id @default(cuid())
  businessId String
  name       String
  address    String   @default("")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("branches")
}

/// MVP: un usuario pertenece a un negocio con un rol. La membresía multi-negocio
/// (tabla user_businesses) queda como extensión futura si un usuario administra varios.
model User {
  id           String     @id @default(cuid())
  businessId   String
  email        String     @unique
  passwordHash String
  name         String
  role         UserRole   @default(seller)
  status       UserStatus @default(active)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("users")
}

model Plan {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  priceMonthly Int      @default(0)
  maxUsers     Int      @default(2)
  maxBranches  Int      @default(1)
  features     Json     @default("[]")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id               String             @id @default(cuid())
  businessId       String             @unique
  planId           String
  status           SubscriptionStatus @default(trial)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     Plan     @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

// --- Catálogo (dominio Productos) — todo aislado por businessId ---

model Category {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String   @default("")
  color       String   @default("#64748b")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([businessId])
  @@map("categories")
}

model Brand {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([businessId])
  @@map("brands")
}

model Product {
  id          String   @id @default(cuid())
  businessId  String
  sku         String
  barcode     String   @default("")
  name        String
  description String   @default("")
  categoryId  String?
  brandId     String?
  costPrice   Decimal  @default(0) @db.Decimal(14, 2)
  salePrice   Decimal  @default(0) @db.Decimal(14, 2)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  imageUrl    String?
  isActive    Boolean  @default(true)
  isFavorite  Boolean  @default(false)
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand    Brand?    @relation(fields: [brandId], references: [id], onDelete: SetNull)

  // SKU único por negocio (permite mismo SKU en negocios distintos).
  @@unique([businessId, sku])
  @@index([businessId])
  @@index([businessId, categoryId])
  @@map("products")
}

model Customer {
  id          String    @id @default(cuid())
  businessId  String
  name        String
  phone       String    @default("")
  email       String    @default("")
  document    String    @default("")
  cuit        String    @default("")
  address     String    @default("")
  birthDate   DateTime?
  notes       String    @default("")
  tags        String[]  @default([])
  isActive    Boolean   @default(true)
  // Deuda de cuenta corriente (>= 0). La gestiona el dominio Ventas/Cuenta corriente; acá es cache.
  debtBalance Decimal   @default(0) @db.Decimal(14, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("customers")
}
