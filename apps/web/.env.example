# Modo de la app: "demo" (datos locales, sin backend) o "prod" (backend real).
# Por defecto "demo". En "prod" el login/registro usan el backend (@mostrador/api).
VITE_APP_MODE=demo

# URL base del backend (solo se usa en modo prod).
# Dev local: el backend en tu Mac. Producción: la URL del backend en la VPS.
VITE_API_URL=http://localhost:3000/api

# --- Supabase (modo prod: auth + datos + RLS) ---
# Públicas: la RLS es lo que protege los datos. Mismo proyecto que usa la landing.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Secrets de las Edge Functions (NO van en el frontend) ---
# Se cargan con:  supabase secrets set MP_ACCESS_TOKEN=... APP_URL=... ALLOWED_ORIGIN=...
#   MP_ACCESS_TOKEN  → Access Token de Mercado Pago (Credenciales de producción).
#   APP_URL          → URL de la PWA del SaaS, para las back_urls del checkout (ej. https://app.ifpos.app).
#   ALLOWED_ORIGIN   → Origen de la landing para CORS (ej. https://ifpos.app). Vacío = cualquiera.
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY los inyecta la plataforma sola.
