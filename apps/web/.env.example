# Modo de la app: "demo" (datos locales, sin backend) o "prod" (backend real).
# Por defecto "demo". En "prod" el login/registro usan el backend (@mostrador/api).
VITE_APP_MODE=demo

# URL base del backend (solo se usa en modo prod).
# Dev local: el backend en tu Mac. Producción: la URL del backend en la VPS.
VITE_API_URL=http://localhost:3000/api
